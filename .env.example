# Local-only env for development. Copy to .env (gitignored) and fill in.
# The shipped Swift app does NOT read these — it posts telemetry to a public
# Supabase Edge Function that holds the DB key server-side. These are only for
# the legacy C++ build / local testing.

# Optional: override the telemetry Edge Function URL the Swift app posts to.
# TELEMETRY_ENDPOINT="https://<project-ref>.supabase.co/functions/v1/telemetry"

# Legacy C++ app only (direct Supabase REST insert). Publishable key = RLS
# insert-only. Leave blank to disable telemetry in the C++ build.
# SUPABASE_URL="https://<project-ref>.supabase.co/rest/v1/telemetry_events"
# SUPABASE_API_KEY="sb_publishable_xxx"
